rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function ownsExistingDoc() {
      return signedIn() && resource.data.ownerUid == request.auth.uid;
    }

    function ownsNewDoc() {
      return signedIn() && request.resource.data.ownerUid == request.auth.uid;
    }

    function isInstructor() {
      return signedIn() && request.auth.token.instructor == true;
    }

    function rosterFieldsAreSafe() {
      return request.resource.data.keys().hasOnly([
        'name', 'hashedId', 'ownerUid', 'xp', 'level', 'levelName',
        'badgeCount', 'tabsDone', 'seminarTabs', 'bestStreak', 'lastSeen'
      ]);
    }

    function articleClaimFieldsAreSafe() {
      return request.resource.data.keys().hasOnly([
        'claimKey', 'normalizedDoi', 'normalizedTitle', 'ownerUid',
        'status', 'submittedAt', 'updatedAt', 'groupKey', 'groupName',
        'contactName', 'groupMemberCount', 'studentHash', 'articleTitle',
        'journal', 'year', 'doi', 'url', 'replicateTarget', 'newVariable',
        'newVariableReason'
      ]);
    }

    function articleGroupFieldsAreSafe() {
      return request.resource.data.keys().hasOnly([
        'groupKey', 'normalizedGroupName', 'ownerUid', 'status',
        'submittedAt', 'updatedAt', 'groupName', 'contactName',
        'memberNames', 'memberCount', 'notes', 'studentHash'
      ]);
    }

    match /students/{hashedId} {
      allow read: if ownsExistingDoc() || isInstructor();
      allow create: if ownsNewDoc() && request.resource.data.hashedId == hashedId;
      allow update: if ownsExistingDoc()
        && request.resource.data.ownerUid == resource.data.ownerUid
        && request.resource.data.hashedId == hashedId;
      allow delete: if ownsExistingDoc() || isInstructor();
    }

    match /roster/{hashedId} {
      allow read: if signedIn();
      allow create: if ownsNewDoc()
        && rosterFieldsAreSafe()
        && request.resource.data.hashedId == hashedId;
      allow update: if ownsExistingDoc()
        && rosterFieldsAreSafe()
        && request.resource.data.ownerUid == resource.data.ownerUid
        && request.resource.data.hashedId == hashedId;
      allow delete: if ownsExistingDoc() || isInstructor();
    }

    match /detail/{hashedId} {
      allow read: if isInstructor();
      allow create: if ownsNewDoc() && request.resource.data.hashedId == hashedId;
      allow update: if ownsExistingDoc()
        && request.resource.data.ownerUid == resource.data.ownerUid
        && request.resource.data.hashedId == hashedId;
      allow delete: if ownsExistingDoc() || isInstructor();
    }

    match /articleClaims/{claimKey} {
      allow read: if signedIn();
      allow create: if signedIn()
        && articleClaimFieldsAreSafe()
        && request.resource.data.ownerUid == request.auth.uid
        && request.resource.data.claimKey == claimKey;
      allow update: if articleClaimFieldsAreSafe()
        && request.resource.data.claimKey == claimKey
        && (
          (signedIn()
            && resource.data.ownerUid == request.auth.uid
            && request.resource.data.ownerUid == resource.data.ownerUid)
          || isInstructor()
        );
      allow delete: if isInstructor();
    }

    match /articleGroups/{groupKey} {
      allow read: if signedIn();
      allow create: if signedIn()
        && articleGroupFieldsAreSafe()
        && request.resource.data.ownerUid == request.auth.uid
        && request.resource.data.groupKey == groupKey;
      allow update: if articleGroupFieldsAreSafe()
        && request.resource.data.groupKey == groupKey
        && (
          (signedIn()
            && resource.data.ownerUid == request.auth.uid
            && request.resource.data.ownerUid == resource.data.ownerUid)
          || isInstructor()
        );
      allow delete: if isInstructor();
    }
  }
}
