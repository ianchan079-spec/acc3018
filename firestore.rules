rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function ownsExistingDoc() {
      return signedIn() && resource.data.ownerUid == request.auth.uid;
    }

    function ownsNewDoc() {
      return signedIn() && request.resource.data.ownerUid == request.auth.uid;
    }

    function isInstructor() {
      return signedIn() && request.auth.token.instructor == true;
    }

    function rosterFieldsAreSafe() {
      return request.resource.data.keys().hasOnly([
        'name', 'hashedId', 'ownerUid', 'xp', 'level', 'levelName',
        'badgeCount', 'tabsDone', 'seminarTabs', 'bestStreak', 'lastSeen'
      ]);
    }

    match /students/{hashedId} {
      allow read: if ownsExistingDoc() || isInstructor();
      allow create: if ownsNewDoc() && request.resource.data.hashedId == hashedId;
      allow update: if ownsExistingDoc()
        && request.resource.data.ownerUid == resource.data.ownerUid
        && request.resource.data.hashedId == hashedId;
      allow delete: if ownsExistingDoc() || isInstructor();
    }

    match /roster/{hashedId} {
      allow read: if signedIn();
      allow create: if ownsNewDoc()
        && rosterFieldsAreSafe()
        && request.resource.data.hashedId == hashedId;
      allow update: if ownsExistingDoc()
        && rosterFieldsAreSafe()
        && request.resource.data.ownerUid == resource.data.ownerUid
        && request.resource.data.hashedId == hashedId;
      allow delete: if ownsExistingDoc() || isInstructor();
    }

    match /detail/{hashedId} {
      allow read: if isInstructor();
      allow create: if ownsNewDoc() && request.resource.data.hashedId == hashedId;
      allow update: if ownsExistingDoc()
        && request.resource.data.ownerUid == resource.data.ownerUid
        && request.resource.data.hashedId == hashedId;
      allow delete: if ownsExistingDoc() || isInstructor();
    }
  }
}
